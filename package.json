{
  "name": "open-from-webroot",
  "displayName": "Open from Webroot",
  "description": "Run files in browser relative to webroot",
  "version": "0.0.1",
  "publisher": "josephfinley",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extension.openFromWebroot"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.openFromWebroot",
        "title": "Open from Webroot"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.openFromWebroot",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Open from Webroot",
      "properties": {
        "openFromWebroot.host": {
          "type": "string",
          "default": "127.0.0.1:8500",
          "description": "Host and port for the browser"
        },
        "openFromWebroot.webroot": {
          "type": "string",
          "default": "",
          "description": "Web root directory path"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "open": "^7.4.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joefinley/open-from-webroot.git"
  }
}
